defmodule Dialup.App.Error do
  @moduledoc """
  Error page rendered for 404 and 500 responses.
  """

  use Dialup.Error

  @impl true
  def render(status, assigns) do
    ~H"""
    <div class="error-page">
      <h1 class="error-code">{@status}</h1>
      <p class="error-message">{@message}</p>
      <a ws-href="/">← Back to home</a>
    </div>
    """
  end
end
