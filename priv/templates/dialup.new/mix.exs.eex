defmodule <%= mod %>.MixProject do
  use Mix.Project

  def project do
    [
      app: :<%= app %>,
      version: "0.1.0",
      elixir: "~> 1.19",
      start_permanent: Mix.env() == :prod,
      deps: deps()
    ]
  end

  def application do
    [
      mod: {<%= mod %>, []},
      extra_applications: [:logger]
    ]
  end

  defp deps do
    [
      {:dialup, "~> <%= dialup_version %>"}
    ]
  end
end
